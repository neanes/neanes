{
  "globs": [
    "*.md",
    ".github/**/*.md",
    "docs/**/*.md",
    "notes/**/*.md"
  ],
  "config": {
    "MD013": false,
    "MD024": {
      "siblings_only": true
    },
    "MD033": {
      "allowed_elements": [
        "audio",
        "details",
        "Downloads",
        "kbd",
        "script",
        "source",
        "span",
        "style",
        "summary"
      ]
    }
  }
}
