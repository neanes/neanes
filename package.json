{
  "name": "neanes",
  "productName": "Neanes",
  "version": "0.5.8",
  "private": true,
  "description": "A Byzantine Chant Scorewriter",
  "author": "danielgarthur",
  "repository": {
    "type": "git",
    "url": "https://github.com/neanes/neanes.git"
  },
  "debug": {
    "env": {
      "VITE_DEV_SERVER_URL": "http://127.0.0.1:3344/"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build && electron-builder --publish never",
    "release": "vue-tsc --noEmit && vite build && electron-builder --publish always",
    "lint": "eslint . && prettier --check .",
    "lint:fix": "eslint --fix . && prettier --write .",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "postinstall": "electron-builder install-app-deps",
    "test": "vitest --run",
    "test:dev": "vitest",
    "coverage": "vitest run --coverage",
    "web:dev": "vite --mode web",
    "web:build": "vue-tsc --noEmit && vite build --mode web"
  },
  "main": "dist-electron/main/index.js",
  "dependencies": {
    "electron-updater": "^6.8.3",
    "i18next": "^26.0.8",
    "i18next-pseudo": "^2.2.1",
    "image-size": "^2.0.2",
    "jszip": "^3.10.1",
    "mime-types": "^3.0.2",
    "tex-linebreak": "^0.9.0",
    "throttle-debounce": "^5.0.2"
  },
  "devDependencies": {
    "@babel/preset-typescript": "^7.28.5",
    "@ckeditor/ckeditor5-vue": "^8.0.0",
    "@ckpack/vue-color": "^1.6.0",
    "@nabla/vite-plugin-eslint": "^3.0.1",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^25.6.0",
    "@types/semver": "^7.7.1",
    "@types/throttle-debounce": "^5.0.2",
    "@types/webpack-env": "^1.18.8",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/coverage-istanbul": "^4.1.5",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "ckeditor5": "^48.0.1",
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1",
    "eslint": "^10.3.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-vue": "^10.9.0",
    "html-to-image": "^1.11.13",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-vue": "^5.4.0",
    "jest-matcher-deep-close-to": "^3.0.2",
    "mitt": "^3.0.1",
    "prettier": "^3.8.3",
    "register-service-worker": "^1.7.2",
    "tone": "^15.1.22",
    "typescript": "^6.0.3",
    "uuid": "^14.0.0",
    "vite": "^8.0.10",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-pwa": "^1.3.0",
    "vite-plugin-vue-devtools": "^8.1.2",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.5",
    "vue": "^3.5.33",
    "vue-component-type-helpers": "^3.2.8",
    "vue-draggable-resizable": "^3.0.0",
    "vue-router": "^5.0.6",
    "vue-tsc": "^3.2.8",
    "vue3-observe-visibility": "^1.0.7",
    "vue3-tabs-chrome": "^0.3.3",
    "yaml": "^2.8.4"
  },
  "license": "GPL-3.0-only",
  "packageManager": "npm@11.12.1",
  "engines": {
    "node": ">=22"
  }
}
